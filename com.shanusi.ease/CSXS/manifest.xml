<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0" ExtensionBundleId="com.shanusi.ease" ExtensionBundleVersion="1.1.0"
    ExtensionBundleName="Shanusi Ease" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.shanusi.ease.panel" Version="1.1.0"/>
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <!-- AEFT 17.0 = After Effects 2020; range luas agar jalan di versi lebih baru -->
            <Host Name="AEFT" Version="[17.0,99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.shanusi.ease.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/ShanusiEase.jsx</ScriptPath>
                    <CEFCommandLine/>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Shanusi Ease</Menu>
                    <Geometry>
                        <Size><Height>540</Height><Width>300</Width></Size>
                        <MinSize><Height>380</Height><Width>260</Width></MinSize>
                        <MaxSize><Height>1400</Height><Width>640</Width></MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./icons/icon-normal.png</Icon>
                        <Icon Type="RollOver">./icons/icon-rollover.png</Icon>
                        <Icon Type="DarkNormal">./icons/icon-darknormal.png</Icon>
                        <Icon Type="DarkRollOver">./icons/icon-darkrollover.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
